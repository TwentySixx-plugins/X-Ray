{
  "name": "twentysix/x-ray",
  "description": "A visual X-ray for Craft CMS Twig templates — hover any front-end element to see which template or component rendered it, and the variables it received.",
  "type": "craft-plugin",
  "license": "MIT",
  "keywords": [
    "craft",
    "craftcms",
    "craft-plugin",
    "twig",
    "templates",
    "components",
    "debug",
    "developer-tools",
    "inspector"
  ],
  "homepage": "https://github.com/TwentySix-plugins/X-Ray",
  "authors": [
    {
      "name": "TwentySix",
      "homepage": "https://github.com/TwentySix-plugins"
    }
  ],
  "support": {
    "issues": "https://github.com/TwentySix-plugins/X-Ray/issues",
    "source": "https://github.com/TwentySix-plugins/X-Ray",
    "docs": "https://github.com/TwentySix-plugins/X-Ray/blob/main/README.md"
  },
  "require": {
    "php": ">=8.2",
    "craftcms/cms": "^5.0.0"
  },
  "autoload": {
    "psr-4": {
      "twentysix\\xray\\": "src/"
    }
  },
  "extra": {
    "handle": "x-ray",
    "name": "X-Ray",
    "developer": "TwentySix",
    "developerUrl": "https://github.com/TwentySix-plugins",
    "documentationUrl": "https://github.com/TwentySix-plugins/X-Ray/blob/main/README.md",
    "changelogUrl": "https://raw.githubusercontent.com/TwentySix-plugins/X-Ray/main/CHANGELOG.md",
    "description": "A visual X-ray for Craft CMS Twig templates — hover any front-end element to see which template or component rendered it, and the variables it received.",
    "class": "twentysix\\xray\\Plugin"
  },
  "config": {
    "allow-plugins": {
      "craftcms/plugin-installer": true
    },
    "sort-packages": true
  }
}
